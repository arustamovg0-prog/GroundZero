generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Lead {
  id        String      @id @default(uuid())
  name      String
  email     String?
  phone     String?
  company   String?
  teamSize  Int?
  term      Int?
  segment   String?     // Open Space / Team Office / Corporate
  status    String      @default("NEW") // NEW, PRIORITY_CLIENT, CONTACTED, WON, LOST
  priority  Boolean     @default(false)
  utm       String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  events    LeadEvent[]
  downloads Download[]
}

model LeadEvent {
  id        String   @id @default(uuid())
  leadId    String
  type      String   // PRE_QUALIFICATION, FORM_SUBMIT, STATUS_CHANGE
  details   String?
  createdAt DateTime @default(now())

  lead      Lead     @relation(fields: [leadId], references: [id])
}

model Download {
  id        String   @id @default(uuid())
  email     String
  pdfName   String
  leadId    String?
  createdAt DateTime @default(now())

  lead      Lead?    @relation(fields: [leadId], references: [id])
}

model Inventory {
  id        String   @id @default(uuid())
  branch    String
  product   String
  status    String   // AVAILABLE, LIMITED, FULL
  updatedAt DateTime @updatedAt
}

model LandingPage {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String?
  content     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Settings {
  id    String @id @default(uuid())
  key   String @unique
  value String
}
